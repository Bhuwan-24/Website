# MongoDB connection string (Replace with your actual Atlas URI)
# Format: mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/<database_name>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://admin:yourpassword@cluster0.abcde.mongodb.net/InquiryDB?retryWrites=true&w=majority

# Port for the server
PORT=5000

# CORS settings (Use '*' for development or your specific domain for production)
CORS_ORIGIN=*
